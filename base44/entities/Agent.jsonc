{
  "name": "Agent",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "title": "Name"
    },
    "role": {
      "type": "string",
      "title": "Role"
    },
    "photo": {
      "type": "string",
      "title": "Photo URL"
    },
    "phone": {
      "type": "string",
      "title": "Phone"
    },
    "whatsapp": {
      "type": "string",
      "title": "WhatsApp"
    },
    "email": {
      "type": "string",
      "title": "Email"
    },
    "about": {
      "type": "string",
      "title": "About / Bio"
    },
    "bitrix_user_id": {
      "type": "number",
      "title": "Bitrix24 User ID"
    },
    "active": {
      "type": "boolean",
      "title": "Active",
      "default": true
    },
    "sort_order": {
      "type": "number",
      "title": "Sort Order"
    }
  },
  "required": [
    "name",
    "role"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {},
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}